# This file is now OPTIONAL. If you don't create a .env with SECRET_KEY,
# the container generates one automatically on first start and reuses it
# on every future restart (saved to ./data/secret_key on the host).
#
# Only fill this in if you specifically want to set your own key, e.g. to
# reuse the same key across a rebuild-from-scratch, or across multiple
# servers.
#
# Generate a key with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-value
ENABLE_SYNCTHING=false
ENABLE_EMAIL=true
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=you@yourdomain.com
SMTP_TO=target@targetdomain.at
SMTP_USE_TLS=true
